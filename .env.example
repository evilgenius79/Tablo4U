# Tablo account (required unless running in MOCK mode)
TABLO_EMAIL=""
TABLO_PASSWORD=""
# Optional: pick a specific device by serverId if you have more than one
TABLO_SERVER_ID=""

# Admin password. If set, it always wins: the admin login is (re)set to it on
# every start. If blank, a random one is generated and printed to the console
# on first start. You can add/remove users in the app afterward.
ADMIN_PASSWORD=""

# Port for the web UI (default 3400)
PORT="3400"

# NOTE: there is no TUNER_COUNT setting — the tuner count is read from the
# device itself after login (only OTA channels use a tuner; OTT don't).

# Where DVR recordings are saved (a folder on the machine running Tablo4U).
# Defaults to a "recordings" folder next to the exe. Admins can also change
# this in the app (DVR → Change…).
RECORDINGS_DIR=""

# Set OPEN=1 to disable login entirely (LAN convenience). Leave blank to
# require sign-in.
OPEN=""

# Set MOCK=1 to run with sample data and a test-pattern stream, no Tablo.
MOCK=""

# OTT (FAST) channels are remuxed (copied) by default — light and works for
# most setups. If OTT feeds skip/break up on your host, set OTT_TRANSCODE=1 to
# re-encode them to a continuous H.264/AAC stream (smooths ad-break
# discontinuities, at the cost of CPU).
OTT_TRANSCODE=""

# Experimental: play OTT channels' HLS directly in the browser (hls.js), with no
# server ffmpeg — lighter, and adaptive bitrate is handled by the browser.
# Requires the OTT CDN to allow CORS; if playback fails, leave this off to use
# the server ffmpeg path. OTA is unaffected.
OTT_DIRECT_HLS=""

# Set STREAM_DEBUG=1 to print ffmpeg progress (speed=, fps, drops) to the
# console — useful for diagnosing a channel that buffers or won't start.
STREAM_DEBUG=""

# Session cookie secret — set to a fixed random string so logins survive
# restarts (otherwise a new random secret is used each start).
SESSION_SECRET=""
