# Tablo account (required unless running in MOCK mode)
TABLO_EMAIL=""
TABLO_PASSWORD=""
# Optional: pick a specific device by serverId if you have more than one
TABLO_SERVER_ID=""

# First-run admin password. If blank, a random one is generated and printed
# to the console on first start. You can add/remove users in the app after.
ADMIN_PASSWORD=""

# Port for the web UI (default 3400)
PORT="3400"

# Max concurrent streams / tuners (default 4)
TUNER_COUNT="4"

# Set OPEN=1 to disable login entirely (LAN convenience). Leave blank to
# require sign-in.
OPEN=""

# Set MOCK=1 to run with sample data and a test-pattern stream, no Tablo.
MOCK=""

# Session cookie secret — set to a fixed random string so logins survive
# restarts (otherwise a new random secret is used each start).
SESSION_SECRET=""
