# Tablo account (required unless running in MOCK mode)
TABLO_EMAIL=""
TABLO_PASSWORD=""
# Optional: pick a specific device by serverId if you have more than one
TABLO_SERVER_ID=""

# Web UI login (optional). If APP_PASSWORD is blank the UI is open on your LAN.
APP_USER="admin"
APP_PASSWORD=""

# Port for the web UI (default 3400)
PORT="3400"

# Session cookie secret (set to a random string in production)
SESSION_SECRET=""
